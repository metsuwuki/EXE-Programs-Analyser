# Rust build outputs
/target/

# Project artifacts
/dist/
/logs/

# Runtime WebView caches (can appear in local runs)
*.WebView2/
EBWebView/

# Installer-generated visuals
/installer/assets/*.bmp

# Temp and logs
*.log
*.tmp
*.temp
*.bak
*.orig
*.rej

# Rust backup files
**/*.rs.bk

# IDE/editor
/.idea/
/.vscode/*
!/.vscode/extensions.json
!/.vscode/settings.json
!/.vscode/tasks.json

# OS junk
Thumbs.db
Desktop.ini
.DS_Store
